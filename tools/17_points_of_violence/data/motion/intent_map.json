{
  "schema": "seventeen.motionIntentMap.v1",
  "defaultIntent": "punch_mid",
  "defaultWeaponScope": "unarmed",
  "candidateLimit": 10,
  "diagnosticActions": ["unknown", "emote", "hit_flinch", "fall", "land"],
  "intents": [
    { "id": "idle", "label": "Idle / Guard", "actions": ["idle", "guard"], "targets": ["none", "unknown"] },
    { "id": "approach", "label": "Approach", "actions": ["locomotion"], "movement": ["advance", "lateral", "in_place"] },
    { "id": "retreat", "label": "Retreat", "actions": ["locomotion", "dodge"], "movement": ["retreat", "lateral"] },
    { "id": "turn", "label": "Turn / Spin", "turnTypes": ["turn", "turn_left", "turn_right", "turn_around", "spin"] },
    { "id": "punch_high", "label": "Punch High", "actions": ["punch"], "targets": ["high"] },
    { "id": "punch_mid", "label": "Punch Mid", "actions": ["punch"], "targets": ["mid"] },
    { "id": "punch_low", "label": "Punch Low", "actions": ["punch"], "targets": ["low"] },
    { "id": "kick_high", "label": "Kick High", "actions": ["kick"], "targets": ["high"] },
    { "id": "kick_mid", "label": "Kick Mid", "actions": ["kick"], "targets": ["mid"] },
    { "id": "kick_low", "label": "Kick Low", "actions": ["kick"], "targets": ["low"] },
    { "id": "block", "label": "Block", "actions": ["block", "guard"], "targets": ["none", "unknown"] },
    { "id": "dodge", "label": "Dodge", "actions": ["dodge"] },
    { "id": "jump", "label": "Jump", "actions": ["jump"], "movement": ["airborne"] },
    { "id": "hit_flinch", "label": "Hit / Flinch", "actions": ["hit_flinch", "fall", "land"], "diagnosticsOnly": true },
    { "id": "emote", "label": "Emote", "actions": ["emote"], "diagnosticsOnly": true }
  ]
}
